// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStage {
  TARGET
  ENRICHING
  ENRICHED
  CONTACTED
  ENGAGED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum ActivityType {
  EMAIL_SENT
  EMAIL_REPLY
  CALL_ATTEMPT
  CALL_CONNECTED
  MEETING
  NOTE
}

enum TaskType {
  CALL
  EMAIL_FOLLOWUP
  VERIFY_CONTACT
  RESEARCH
}

enum TaskStatus {
  OPEN
  DONE
  SNOOZED
}

enum OutreachChannel {
  EMAIL
  CALL
}

enum OutreachTouchStatus {
  PENDING
  SENT
  REPLIED
  FAILED
}

enum LeadDiscoveryJobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

enum LeadCandidateStatus {
  NEW
  REVIEWED
  PROMOTED
  REJECTED
}

model Account {
  id               String           @id @default(uuid()) @db.Uuid
  companyName      String
  industry         String?
  orgType          String?
  whatTheyMove     String?
  whyHireCouriers  String?
  website          String?
  phone            String?
  address1         String?
  city             String?
  state            String?
  zip              String?
  region           String?
  stage            AccountStage @default(TARGET)
  priorityScore    Float?
  notes            String?
  sourceRowJson    Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  contacts         Contact[]
  activities       Activity[]
  tasks            Task[]
  outreachTouches  OutreachTouch[]
  leadCandidates   LeadCandidate[]

  @@index([companyName])
  @@index([stage])
  @@index([state])
  @@index([region])
}

model Contact {
  id             String         @id @default(uuid()) @db.Uuid
  accountId      String         @db.Uuid
  firstName      String?
  lastName       String?
  fullName       String?
  title          String?
  department     String?
  email          String?
  phone          String?
  linkedinUrl    String?
  confidenceScore Float?
  source         String?
  lastVerifiedAt DateTime?
  isDoNotContact Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  account        Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  activities     Activity[]
  tasks          Task[]
  outreachTouches OutreachTouch[]

  @@index([accountId])
  @@index([email])
  @@index([lastName])
  @@index([isDoNotContact])
}

model Activity {
  id         String       @id @default(uuid()) @db.Uuid
  accountId  String       @db.Uuid
  contactId  String?      @db.Uuid
  type       ActivityType
  outcome    String?
  content    String?
  occurredAt DateTime     @default(now())
  createdAt  DateTime     @default(now())

  account    Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact    Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([contactId])
  @@index([type])
  @@index([occurredAt])
}

model Task {
  id         String     @id @default(uuid()) @db.Uuid
  accountId  String     @db.Uuid
  contactId  String?    @db.Uuid
  type       TaskType
  status     TaskStatus @default(OPEN)
  dueAt      DateTime?
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  account    Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact    Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([dueAt])
  @@index([accountId])
}

model OutreachSequence {
  id        String          @id @default(uuid()) @db.Uuid
  name      String
  channel   OutreachChannel
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())

  touches   OutreachTouch[]
}

model OutreachTouch {
  id          String              @id @default(uuid()) @db.Uuid
  sequenceId  String              @db.Uuid
  accountId   String              @db.Uuid
  contactId   String?             @db.Uuid
  stepNumber  Int
  status      OutreachTouchStatus @default(PENDING)
  scheduledAt DateTime?
  sentAt      DateTime?
  metaJson    Json?
  createdAt   DateTime            @default(now())

  sequence    OutreachSequence    @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  account     Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact     Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([sequenceId])
  @@index([accountId])
  @@index([status])
  @@index([scheduledAt])
}

model LeadDiscoveryJob {
  id           String                 @id @default(uuid()) @db.Uuid
  query        String
  region       String?
  state        String?
  status       LeadDiscoveryJobStatus @default(QUEUED)
  attemptCount Int                    @default(0)
  resultCount  Int                    @default(0)
  lastError    String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  candidates   LeadCandidate[]

  @@index([status])
  @@index([createdAt])
}

model LeadCandidate {
  id                String              @id @default(uuid()) @db.Uuid
  discoveryJobId    String              @db.Uuid
  accountId         String?             @db.Uuid
  companyName       String
  website           String?
  state             String?
  region            String?
  signalType        String?
  signalSummary     String?
  sourceUrl         String?
  sourcePublishedAt DateTime?
  confidenceScore   Float?
  dedupeKey         String?
  status            LeadCandidateStatus @default(NEW)
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  discoveryJob      LeadDiscoveryJob    @relation(fields: [discoveryJobId], references: [id], onDelete: Cascade)
  account           Account?            @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([companyName])
  @@index([state])
  @@index([region])
  @@index([accountId])
  @@index([discoveryJobId])
  @@index([dedupeKey])
}
