// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStage {
  TARGET
  ENRICHING
  ENRICHED
  CONTACTED
  ENGAGED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum ActivityType {
  EMAIL_SENT
  EMAIL_REPLY
  CALL_ATTEMPT
  CALL_CONNECTED
  MEETING
  NOTE
}

enum TaskType {
  CALL
  EMAIL_FOLLOWUP
  VERIFY_CONTACT
  RESEARCH
}

enum TaskStatus {
  OPEN
  DONE
  SNOOZED
}

enum OutreachChannel {
  EMAIL
  CALL
}

enum OutreachTouchStatus {
  PENDING
  SENT
  REPLIED
  FAILED
}

enum LeadDiscoveryJobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

enum LeadCandidateStatus {
  NEW
  REVIEWED
  PROMOTED
  REJECTED
}

enum DeliveryStatus {
  pending
  assigned
  en_route_to_pickup
  picked_up
  en_route_to_delivery
  delivered
  issue_reported
  cancelled
}

enum DeliveryPriority {
  standard
  urgent
}

enum IssueStatus {
  open
  resolved
}

enum IssueType {
  delayed
  customer_unavailable
  pickup_problem
  address_issue
  vehicle_problem
  other
}

model Driver {
  id          String          @id @default(uuid()) @db.Uuid
  name        String
  phone       String?
  email       String?
  vehicleName String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  deliveries  Delivery[]
  location    DriverLocation?

  @@index([isActive])
}

model DriverLocation {
  id         String   @id @default(uuid()) @db.Uuid
  driverId   String   @unique @db.Uuid
  lat        Float
  lng        Float
  accuracy   Float?
  capturedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([capturedAt])
}

model Delivery {
  id                        String           @id @default(uuid()) @db.Uuid
  customerId                String?          @db.Uuid
  pickupDateTime            DateTime?
  requestedDeliveryDateTime DateTime
  pickupAddress             String
  deliveryAddress           String
  pickupContactName         String?
  pickupContactPhone        String?
  deliveryContactName       String?
  deliveryContactPhone      String?
  packageNotes              String?
  dispatcherNotes           String?
  priorityLevel             DeliveryPriority @default(standard)
  status                    DeliveryStatus   @default(pending)
  assignedDriverId          String?          @db.Uuid
  createdBy                 String
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  // Phase timestamps for operational tracking
  assignedAt                DateTime?
  pickedUpAt                DateTime?
  deliveredAt               DateTime?
  cancelledAt               DateTime?

  // Route sequencing
  stopOrder                 Int?

  // Geo readiness (populated by geocoding on create/update)
  pickupLat                 Float?
  pickupLng                 Float?
  deliveryLat               Float?
  deliveryLng               Float?

  customer                  Account?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignedDriver            Driver?          @relation(fields: [assignedDriverId], references: [id], onDelete: SetNull)
  statusHistory             DeliveryStatusHistory[]
  issues                    DeliveryIssue[]

  @@index([status])
  @@index([assignedDriverId])
  @@index([customerId])
  @@index([priorityLevel])
  @@index([requestedDeliveryDateTime])
  @@index([deliveredAt])
  @@index([stopOrder])
}

model DeliveryIssue {
  id          String      @id @default(uuid()) @db.Uuid
  deliveryId  String      @db.Uuid
  reportedBy  String
  issueType   IssueType
  note        String?
  status      IssueStatus @default(open)
  createdAt   DateTime    @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
  resolveNote String?

  delivery    Delivery    @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@index([status])
  @@index([createdAt])
}

model DeliveryStatusHistory {
  id         String         @id @default(uuid()) @db.Uuid
  deliveryId String         @db.Uuid
  oldStatus  DeliveryStatus?
  newStatus  DeliveryStatus
  changedBy  String
  changedAt  DateTime       @default(now())
  note       String?

  delivery   Delivery       @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@index([changedAt])
}

model Account {
  id               String           @id @default(uuid()) @db.Uuid
  companyName      String
  industry         String?
  orgType          String?
  whatTheyMove     String?
  whyHireCouriers  String?
  website          String?
  phone            String?
  address1         String?
  city             String?
  state            String?
  zip              String?
  region           String?
  stage            AccountStage @default(TARGET)
  priorityScore    Float?
  notes            String?
  sourceRowJson    Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  contacts         Contact[]
  activities       Activity[]
  tasks            Task[]
  outreachTouches  OutreachTouch[]
  leadCandidates   LeadCandidate[]
  deliveries       Delivery[]

  @@index([companyName])
  @@index([stage])
  @@index([state])
  @@index([region])
}

model Contact {
  id             String         @id @default(uuid()) @db.Uuid
  accountId      String         @db.Uuid
  firstName      String?
  lastName       String?
  fullName       String?
  title          String?
  department     String?
  email          String?
  phone          String?
  linkedinUrl    String?
  confidenceScore Float?
  source         String?
  lastVerifiedAt DateTime?
  isDoNotContact Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  account        Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  activities     Activity[]
  tasks          Task[]
  outreachTouches OutreachTouch[]

  @@index([accountId])
  @@index([email])
  @@index([lastName])
  @@index([isDoNotContact])
}

model Activity {
  id         String       @id @default(uuid()) @db.Uuid
  accountId  String       @db.Uuid
  contactId  String?      @db.Uuid
  type       ActivityType
  outcome    String?
  content    String?
  occurredAt DateTime     @default(now())
  createdAt  DateTime     @default(now())

  account    Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact    Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([contactId])
  @@index([type])
  @@index([occurredAt])
}

model Task {
  id         String     @id @default(uuid()) @db.Uuid
  accountId  String     @db.Uuid
  contactId  String?    @db.Uuid
  type       TaskType
  status     TaskStatus @default(OPEN)
  dueAt      DateTime?
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  account    Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact    Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([dueAt])
  @@index([accountId])
}

model OutreachSequence {
  id        String          @id @default(uuid()) @db.Uuid
  name      String
  channel   OutreachChannel
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())

  touches   OutreachTouch[]
}

model OutreachTouch {
  id          String              @id @default(uuid()) @db.Uuid
  sequenceId  String              @db.Uuid
  accountId   String              @db.Uuid
  contactId   String?             @db.Uuid
  stepNumber  Int
  status      OutreachTouchStatus @default(PENDING)
  scheduledAt DateTime?
  sentAt      DateTime?
  metaJson    Json?
  createdAt   DateTime            @default(now())

  sequence    OutreachSequence    @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  account     Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact     Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([sequenceId])
  @@index([accountId])
  @@index([status])
  @@index([scheduledAt])
}

model LeadDiscoveryJob {
  id           String                 @id @default(uuid()) @db.Uuid
  query        String
  region       String?
  state        String?
  status       LeadDiscoveryJobStatus @default(QUEUED)
  attemptCount Int                    @default(0)
  resultCount  Int                    @default(0)
  lastError    String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  candidates   LeadCandidate[]

  @@index([status])
  @@index([createdAt])
}

model LeadCandidate {
  id                String              @id @default(uuid()) @db.Uuid
  discoveryJobId    String              @db.Uuid
  accountId         String?             @db.Uuid
  companyName       String
  website           String?
  state             String?
  region            String?
  signalType        String?
  signalSummary     String?
  sourceUrl         String?
  sourcePublishedAt DateTime?
  confidenceScore   Float?
  dedupeKey         String?
  status            LeadCandidateStatus @default(NEW)
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  discoveryJob      LeadDiscoveryJob    @relation(fields: [discoveryJobId], references: [id], onDelete: Cascade)
  account           Account?            @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([companyName])
  @@index([state])
  @@index([region])
  @@index([accountId])
  @@index([discoveryJobId])
  @@index([dedupeKey])
}
