# Required — PostgreSQL connection string (Neon recommended)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Optional — when set, write API routes require this token
# (sent via the x-admin-token header or entered in the UI's Admin Token field).
# When unset, all writes are open — only suitable for private/internal deployments.
ADMIN_TOKEN=""

# Lead discovery & enrichment providers (all optional; set at least one)
APOLLO_API_KEY=""        # Apollo.io — primary B2B contact search + email/phone enrichment
APOLLO_PLAN_ENABLED=""   # Set to "true" if your Apollo plan includes people/match (single-contact enrichment)
PDL_API_KEY=""           # People Data Labs — person-enrichment fallback (healthcare & non-B2B)
SERPER_API_KEY=""        # Serper — Google search for company discovery + LinkedIn profiles
HUNTER_API_KEY=""        # Hunter.io — domain-level email discovery
INSTANTLY_API_KEY=""     # Instantly.ai — SuperSearch lead database (verified emails)
