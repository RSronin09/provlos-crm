DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
ADMIN_TOKEN="provlos-admin"

# --- Lead discovery / enrichment providers (set at least one) ---
# Apollo.io — primary B2B contact search + email enrichment
APOLLO_API_KEY="apollo-api-key"
# Set to "true" only if your Apollo plan includes the people/match endpoint
# (required for per-contact enrichment; the free tier returns 403 for it)
APOLLO_PLAN_ENABLED="false"
# People Data Labs — enrichment fallback with broader healthcare coverage
PDL_API_KEY="pdl-api-key"
# Serper.dev — Google search for website resolution + LinkedIn discovery
SERPER_API_KEY="serper-api-key"
# Hunter.io — domain email search
HUNTER_API_KEY="hunter-api-key"
# Instantly.ai — SuperSearch lead database (see /crm/discovery)
INSTANTLY_API_KEY="instantly-api-key"

# Public base URL of this deployment (e.g. https://ops.doctorstransport.com).
# Required for Apollo's async phone-number reveal: phone numbers are only
# delivered to a public webhook, never in the synchronous API response.
# On Vercel this falls back to VERCEL_URL automatically.
APP_URL=""
